<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>NexusDeFi | Withdrawals</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(51, 65, 85, 1);
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 10px;
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-container": "#ff516a",
                        "secondary": "#4edea3",
                        "on-surface-variant": "#c2c6d6",
                        "tertiary-fixed-dim": "#ffb2b7",
                        "surface-tint": "#adc6ff",
                        "surface-container-high": "#222a3d",
                        "on-background": "#dae2fd",
                        "tertiary": "#ffb2b7",
                        "on-secondary-container": "#00311f",
                        "surface-variant": "#2d3449",
                        "inverse-surface": "#dae2fd",
                        "outline": "#8c909f",
                        "inverse-primary": "#005ac2",
                        "error-container": "#93000a",
                        "surface-bright": "#31394d",
                        "surface-dim": "#0b1326",
                        "outline-variant": "#424754",
                        "on-tertiary-fixed-variant": "#92002a",
                        "on-secondary": "#003824",
                        "on-primary": "#002e6a",
                        "on-error": "#690005",
                        "primary-container": "#4d8eff",
                        "on-surface": "#dae2fd",
                        "secondary-fixed-dim": "#4edea3",
                        "on-secondary-fixed-variant": "#005236",
                        "primary": "#adc6ff",
                        "tertiary-fixed": "#ffdadb",
                        "background": "#0b1326",
                        "primary-fixed-dim": "#adc6ff",
                        "surface-container-lowest": "#060e20",
                        "on-tertiary": "#67001b",
                        "on-primary-fixed": "#001a42",
                        "surface-container-highest": "#2d3449",
                        "on-primary-fixed-variant": "#004395",
                        "surface": "#0b1326",
                        "surface-container-low": "#131b2e",
                        "on-error-container": "#ffdad6",
                        "primary-fixed": "#d8e2ff",
                        "error": "#ffb4ab",
                        "secondary-fixed": "#6ffbbe",
                        "secondary-container": "#00a572",
                        "inverse-on-surface": "#283044",
                        "on-secondary-fixed": "#002113",
                        "on-primary-container": "#00285d",
                        "on-tertiary-fixed": "#40000d",
                        "surface-container": "#171f33",
                        "on-tertiary-container": "#5b0017"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "base": "4px",
                        "lg": "24px",
                        "sm": "12px",
                        "md": "16px",
                        "xl": "40px",
                        "container-max": "1440px",
                        "xs": "8px",
                        "gutter": "20px"
                    },
                    "fontFamily": {
                        "display-lg": ["Inter"],
                        "label-sm": ["Inter"],
                        "data-md": ["JetBrains Mono"],
                        "body-md": ["Inter"],
                        "headline-md": ["Inter"],
                        "headline-lg": ["Inter"],
                        "data-lg": ["JetBrains Mono"],
                        "body-lg": ["Inter"]
                    },
                    "fontSize": {
                        "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "label-sm": ["12px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "600"}],
                        "data-md": ["14px", {"lineHeight": "20px", "fontWeight": "500"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "data-lg": ["20px", {"lineHeight": "24px", "fontWeight": "500"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen selection:bg-primary/30">
<!-- TopNavBar -->
<header class="fixed top-0 w-full z-50 bg-surface-dim/80 backdrop-blur-xl border-b border-outline-variant/30 flex justify-between items-center px-lg h-20 w-full">
<div class="flex items-center gap-md">
<span class="font-headline-md text-headline-md font-bold text-primary">NexusDeFi</span>
</div>
<div class="hidden md:flex flex-1 max-w-md mx-xl">
<div class="relative w-full">
<span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
<input class="w-full bg-surface-container-low border border-outline-variant/30 rounded-lg pl-xl pr-md py-xs focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Search protocol..." type="text"/>
</div>
</div>
<div class="flex items-center gap-md">
<button class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">notifications</button>
