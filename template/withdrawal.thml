<span class="font-label-sm text-label-sm">Dashboard</span>
</a>
<a class="flex items-center gap-sm text-on-surface-variant px-md py-sm hover:bg-surface-variant/50 hover:text-on-surface transition-all duration-200" href="#">
<span class="material-symbols-outlined">account_balance_wallet</span>
<span class="font-label-sm text-label-sm">Staking</span>
</a>
<a class="flex items-center gap-sm text-on-surface-variant px-md py-sm hover:bg-surface-variant/50 hover:text-on-surface transition-all duration-200" href="#">
<span class="material-symbols-outlined">hub</span>
<span class="font-label-sm text-label-sm">Network</span>
</a>
<a class="flex items-center gap-sm text-on-surface-variant px-md py-sm hover:bg-surface-variant/50 hover:text-on-surface transition-all duration-200" href="#">
<span class="material-symbols-outlined">payments</span>
<span class="font-label-sm text-label-sm">Rewards</span>
</a>
<a class="flex items-center gap-sm bg-secondary-container/10 text-secondary border-r-4 border-secondary px-md py-sm transition-all duration-200" href="#">
<span class="material-symbols-outlined">outbound</span>
<span class="font-label-sm text-label-sm">Withdrawals</span>
</a>
</nav>
<div class="px-md mt-auto space-y-base border-t border-outline-variant/10 pt-lg">
<a class="flex items-center gap-sm text-on-surface-variant px-md py-sm hover:bg-surface-variant/50 hover:text-on-surface transition-all duration-200" href="#">
<span class="material-symbols-outlined">settings</span>
<span class="font-label-sm text-label-sm">Settings</span>
</a>
<a class="flex items-center gap-sm text-on-surface-variant px-md py-sm hover:bg-surface-variant/50 hover:text-on-surface transition-all duration-200" href="#">
<span class="material-symbols-outlined">help</span>
<span class="font-label-sm text-label-sm">Support</span>
</a>
<div class="mt-md">
<button class="w-full bg-secondary text-on-secondary font-bold py-sm rounded-lg active:scale-95 transition-transform flex items-center justify-center gap-xs">
<span class="material-symbols-outlined text-[20px]">add_circle</span>
                    Stake Assets
                </button>
</div>
</div>
</aside>
<!-- Main Content Canvas -->
<main class="ml-64 pt-24 p-lg min-h-screen bg-background">
<div class="max-w-container-max mx-auto">
<!-- Breadcrumbs / Page Header -->
<div class="mb-xl flex justify-between items-end">
<div>
<h1 class="font-headline-lg text-headline-lg text-on-surface">Withdrawal Application</h1>
<p class="text-on-surface-variant mt-xs">Submit a request to move assets to your verified external wallet.</p>
</div>
<div class="flex gap-sm">
<div class="glass-panel px-md py-sm rounded-xl flex items-center gap-sm">
<div class="w-2 h-2 rounded-full bg-secondary animate-pulse"></div>
<span class="font-data-md text-data-md text-secondary">Network: Polygon Mainnet</span>
</div>
</div>
</div>
<div class="grid grid-cols-12 gap-gutter">
<!-- Left Column: Withdrawal Form -->
<div class="col-span-12 lg:col-span-8 space-y-gutter">
<div class="glass-panel rounded-xl p-lg overflow-hidden relative">
<!-- Abstract glow effect -->
<div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 blur-[100px] rounded-full"></div>
<div class="relative z-10">
<h2 class="font-headline-md text-headline-md text-on-surface mb-lg flex items-center gap-sm">
<span class="material-symbols-outlined text-primary">account_balance</span>
                                Withdrawal Form
                            </h2>
<form class="space-y-xl">
<!-- Balance Summary -->
<div class="grid grid-cols-2 gap-md">
<div class="bg-surface-container-low p-md rounded-lg border border-outline-variant/20">
<p class="text-on-surface-variant font-label-sm text-label-sm mb-xs uppercase tracking-wider">Daily Rewards Available</p>
<p class="font-data-lg text-data-lg text-secondary">12,450.00 USDC</p>
</div>
<div class="bg-surface-container-low p-md rounded-lg border border-outline-variant/20">
<p class="text-on-surface-variant font-label-sm text-label-sm mb-xs uppercase tracking-wider">Unclaimed Bonus</p>
<p class="font-data-lg text-data-lg text-primary">3,120.45 USDC</p>
</div>
</div>
<!-- Type Selection -->
<div class="space-y-sm">
<label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest block">Withdrawal Type</label>
<div class="grid grid-cols-2 gap-sm">
<button class="flex items-center justify-between p-md rounded-lg border-2 border-primary bg-primary/5 text-primary transition-all" type="button">
<div class="flex items-center gap-sm">
<span class="material-symbols-outlined">event_note</span>
<span class="font-body-md font-bold">Daily Reward</span>
</div>
<span class="material-symbols-outlined">check_circle</span>
</button>
<button class="flex items-center justify-between p-md rounded-lg border border-outline-variant/30 text-on-surface-variant hover:border-primary/50 transition-all" type="button">
<div class="flex items-center gap-sm">
<span class="material-symbols-outlined">redeem</span>
<span class="font-body-md">Bonus Pool</span>
</div>
</button>
</div>
</div>
<!-- Amount Input -->
<div class="space-y-sm">
<div class="flex justify-between items-end">
<label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest block">Amount to Withdraw</label>
<span class="text-on-surface-variant font-data-md text-data-md">Limit: 50,000 USDC / 24h</span>
</div>
<div class="relative">
<input class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-xl px-lg py-xl font-data-lg text-data-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-outline/30" placeholder="0.00" type="number"/>
<div class="absolute right-md top-1/2 -translate-y-1/2 flex items-center gap-md">
<button class="text-primary font-bold hover:underline transition-all" type="button">MAX</button>
<div class="flex items-center gap-xs bg-surface-variant px-sm py-xs rounded-lg border border-outline-variant/30">
<span class="w-6 h-6 rounded-full bg-[#2775ca] flex items-center justify-center text-[12px] font-bold text-white">S</span>
<span class="font-bold">USDC</span>
</div>
</div>
</div>
</div>
<!-- Dynamic Breakdown -->
<div class="bg-surface-container-high/50 rounded-xl p-md border border-outline-variant/20 space-y-md">
<div class="flex justify-between items-center text-on-surface-variant">
<span class="font-body-md">Network Fee (0.5%)</span>
<span class="font-data-md text-data-md">62.25 USDC</span>
</div>
<div class="flex justify-between items-center text-on-surface-variant">
<span class="font-body-md">Processing Surcharge</span>
<span class="font-data-md text-data-md">0.00 USDC</span>
</div>
<div class="h-[1px] bg-outline-variant/30"></div>
<div class="flex justify-between items-center">
<span class="font-body-lg text-body-lg text-on-surface font-bold">Net Receivable</span>
<span class="font-data-lg text-data-lg text-secondary">12,387.75 USDC</span>
</div>
</div>
<!-- Submit Button -->
<button class="w-full bg-gradient-to-b from-primary-container to-primary-container/80 text-on-primary-container font-bold py-md rounded-xl text-body-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 active:scale-95 transition-all flex items-center justify-center gap-sm" type="submit">
<span class="material-symbols-outlined">send</span>
                                    Request Withdrawal
                                </button>
<p class="text-center text-on-surface-variant text-label-sm flex items-center justify-center gap-xs">
<span class="material-symbols-outlined text-[16px]">lock</span>
                                    Secured by Multi-Sig Verification Protocol
                                </p>
</form>
</div>
</div>
</div>
<!-- Right Column: Policies & History -->
<div class="col-span-12 lg:col-span-4 space-y-gutter">
<!-- Withdrawal Policies Card -->
<div class="glass-panel rounded-xl p-md border-l-4 border-l-primary">
<h3 class="font-headline-md text-headline-md text-on-surface mb-md">Protocol Policies</h3>
<ul class="space-y-sm text-on-surface-variant font-body-md">
<li class="flex gap-sm">
<span class="material-symbols-outlined text-primary text-[20px]">info</span>
<span>Daily limit reset occurs at 00:00 UTC.</span>
</li>
<li class="flex gap-sm">
<span class="material-symbols-outlined text-primary text-[20px]">info</span>
<span>Standard processing time: 5-30 minutes.</span>
</li>
<li class="flex gap-sm">
<span class="material-symbols-outlined text-primary text-[20px]">info</span>
<span>Large withdrawals (&gt;50k) require secondary MFA approval.</span>
</li>
</ul>
</div>
<!-- Recent Withdrawals Card -->
<div class="glass-panel rounded-xl overflow-hidden">
<div class="p-md border-b border-outline-variant/20 flex justify-between items-center bg-surface-container-low">
<h3 class="font-body-md font-bold text-on-surface">Recent Withdrawals</h3>
<button class="text-primary text-label-sm font-bold hover:underline">View All</button>
</div>
<div class="divide-y divide-outline-variant/10">
<!-- Entry 1 -->
<div class="p-md hover:bg-surface-variant/20 transition-colors">
<div class="flex justify-between items-start mb-xs">
<span class="font-data-md text-data-md text-on-surface">2,500.00 USDC</span>
<span class="px-xs py-[2px] bg-secondary/10 text-secondary text-[10px] font-bold uppercase rounded flex items-center gap-[2px]">
<span class="w-1 h-1 bg-secondary rounded-full"></span> Completed
                                    </span>
</div>
<div class="flex justify-between items-center text-label-sm text-on-surface-variant">
<span>2 hours ago</span>
<span class="flex items-center gap-xs">
                                        0x71C...4f9
                                        <span class="material-symbols-outlined text-[14px]">open_in_new</span>
</span>
</div>
</div>
<!-- Entry 2 -->
<div class="p-md hover:bg-surface-variant/20 transition-colors">
<div class="flex justify-between items-start mb-xs">
<span class="font-data-md text-data-md text-on-surface">12,000.00 USDC</span>
<span class="px-xs py-[2px] bg-secondary/10 text-secondary text-[10px] font-bold uppercase rounded flex items-center gap-[2px]">
<span class="w-1 h-1 bg-secondary rounded-full"></span> Completed
                                    </span>
</div>
<div class="flex justify-between items-center text-label-sm text-on-surface-variant">
<span>Yesterday</span>
<span class="flex items-center gap-xs">
                                        0x71C...4f9
                                        <span class="material-symbols-outlined text-[14px]">open_in_new</span>
</span>
</div>
</div>
<!-- Entry 3 -->
<div class="p-md hover:bg-surface-variant/20 transition-colors">
<div class="flex justify-between items-start mb-xs">
<span class="font-data-md text-data-md text-on-surface">450.00 USDC</span>
<span class="px-xs py-[2px] bg-tertiary-container/10 text-tertiary-container text-[10px] font-bold uppercase rounded flex items-center gap-[2px]">
<span class="w-1 h-1 bg-tertiary-container rounded-full"></span> Failed
                                    </span>
</div>
<div class="flex justify-between items-center text-label-sm text-on-surface-variant">
<span>3 days ago</span>
<span class="text-tertiary-container">Invalid Gas</span>
</div>
</div>
</div>
</div>
<!-- Security Banner -->
<div class="relative h-48 rounded-xl overflow-hidden group">
<img alt="Security verification background" class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-60 transition-all duration-700" data-alt="A high-tech digital close-up of a secure server interface with glowing blue lines and hexagonal geometric patterns. The aesthetic is extremely clean and futuristic, representing cyber security and institutional-grade encryption. The lighting is dark with vibrant neon blue highlights that create a sense of deep technical sophistication and trust." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBeTE0bibeJkQSHXP4MLc_SiaDv9m4YDoVIeBMlKGyUII0kcFj59dQz4qN-DEf8XVJffZTOZplOMVjpx1Rrnk9hfV1kFtTk-x0w2O-ZF_KdRvKGlku9akBWcJds5iiH2MMFqETLDGdETyQUDeknxT86Yr241x6pR0UpNOmBa9j-xFDaaaBTtzsZCwA0INlLYETWEN_MBq5T0j6RpoJwlnCYj9r6JsB6QfuvNfRXXQhW4dMwm00IedNlK7s6zveDZBHZPO7hb6QSRw"/>
<div class="absolute inset-0 bg-gradient-to-t from-background to-transparent"></div>
<div class="absolute bottom-md left-md right-md">
<p class="font-bold text-on-surface mb-xs">Cold Storage Policy</p>
<p class="text-label-sm text-on-surface-variant">98% of treasury assets are held in offline vaults for maximum security.</p>
</div>
</div>
</div>
</div>
</div>
</main>
<!-- Micro-interaction Script -->
<script>
        // Simple tab switching for the withdrawal type
        const typeButtons = document.querySelectorAll('button[type="button"]');
        typeButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                // Clear all
                typeButtons.forEach(b => {
                    b.classList.remove('border-primary', 'bg-primary/5', 'text-primary', 'border-2');
                    b.classList.add('border-outline-variant/30', 'text-on-surface-variant', 'border');
                    const icon = b.querySelector('span:last-child');
                    if (icon && icon.innerText === 'check_circle') icon.style.opacity = '0';
                });
                // Set active
                btn.classList.add('border-primary', 'bg-primary/5', 'text-primary', 'border-2');
                btn.classList.remove('border-outline-variant/30', 'text-on-surface-variant', 'border');
                const icon = btn.querySelector('span:last-child');
                if (icon && icon.innerText === 'check_circle') icon.style.opacity = '1';
            });
        });

        // Initialize first button as active visually
        typeButtons[0].click();
    </script>
</body></html>