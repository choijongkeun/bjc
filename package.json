{
  "name": "bjc-offchain-policy-engine",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "node scripts/run_with_env.mjs BJC_API_PORT=3001 -- tsx watch src/server.ts",
    "start": "node scripts/run_with_env.mjs BJC_API_PORT=3001 -- node dist/src/server.js",
    "start:api": "npm start",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "preflight:smoke": "node scripts/run_with_env.mjs -- tsx scripts/smoke_preflight.ts",
    "smoke:mysql": "tsx scripts/mysql_smoke.ts",
    "smoke:member": "tsx scripts/member_referral_binary_smoke.ts",
    "smoke:staking": "tsx scripts/account_staking_smoke.ts",
    "smoke:reward": "tsx scripts/account_reward_smoke.ts",
    "smoke:withdrawal": "tsx scripts/reward_withdrawal_smoke.ts",
    "smoke:direct-referral": "tsx scripts/direct_referral_reward_smoke.ts",
    "smoke:rank-qualification": "tsx scripts/rank_qualification_smoke.ts",
    "smoke:rank-bonus": "tsx scripts/rank_bonus_smoke.ts",
    "smoke:contribution": "tsx scripts/contribution_reward_smoke.ts",
    "smoke:sidecar": "tsx scripts/sidecar_reward_smoke.ts",
    "smoke:all": "npm run preflight:smoke && npm run smoke:member && npm run smoke:staking && npm run smoke:reward && npm run smoke:withdrawal && npm run smoke:direct-referral && npm run smoke:rank-qualification && npm run smoke:rank-bonus && npm run smoke:contribution && npm run smoke:sidecar"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
